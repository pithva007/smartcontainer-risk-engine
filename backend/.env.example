# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smartcontainer_db

# Redis (optional caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ML Microservice
ML_SERVICE_URL=http://localhost:8000

# File Upload
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE_MB=50

# Geocoding (node-geocoder)
# Provider options: openstreetmap, google, mapbox
GEOCODER_PROVIDER=openstreetmap
GEOCODER_API_KEY=your_api_key_here

# Mapbox (for enhanced routing)
MAPBOX_API_KEY=your_mapbox_token_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT (future auth)
JWT_SECRET=change_this_secret_in_production

# Logging
LOG_LEVEL=info
